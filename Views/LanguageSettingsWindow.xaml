<hc:Window
    x:Class="SceneTodo.Views.LanguageSettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:SceneTodo.Models"
    xmlns:services="clr-namespace:SceneTodo.Services"
    Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_Language]}"
    Width="500"
    Height="400"
    Background="{DynamicResource RegionBrush}"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,20"
            FontSize="18"
            FontWeight="Bold"
            Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_Language]}" />

        <ScrollViewer
            Grid.Row="1"
            VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Margin="0,0,0,15">
                    <GroupBox.Header>
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_Language]}" />
                    </GroupBox.Header>

                    <StackPanel Margin="10">
                        <TextBlock
                            Margin="0,0,0,10"
                            Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_Language]}"
                            TextWrapping="Wrap" />

                        <ComboBox
                            x:Name="LanguageComboBox"
                            DisplayMemberPath="Description"
                            SelectedValuePath="Value"
                            SelectionChanged="LanguageComboBox_SelectionChanged" />

                        <CheckBox
                            x:Name="AutoDetectCheckBox"
                            Margin="0,15,0,0"
                            Checked="AutoDetectCheckBox_Changed"
                            Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Language_AutoDetect]}"
                            Unchecked="AutoDetectCheckBox_Changed" />

                        <Border
                            Margin="0,15,0,0"
                            Padding="10"
                            Background="{DynamicResource InfoBrush}"
                            CornerRadius="4">
                            <TextBlock
                                Foreground="{DynamicResource TextIconBrush}"
                                Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Language_RestartRequired]}"
                                TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </GroupBox>

                <GroupBox>
                    <GroupBox.Header>
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Language_Information]}" />
                    </GroupBox.Header>

                    <StackPanel Margin="10">
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Language_SupportedLanguages]}" />
                        <TextBlock
                            Margin="10,5,0,0"
                            Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Language_ChineseSimplified]}" />
                        <TextBlock
                            Margin="10,5,0,0"
                            Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Language_English]}" />

                        <TextBlock
                            Margin="0,15,0,0"
                            Foreground="{DynamicResource SecondaryTextBrush}"
                            Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Language_MoreComingSoon]}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel
            Grid.Row="2"
            Margin="0,20,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="100"
                Margin="0,0,10,0"
                Click="SaveButton_Click"
                Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Common_Save]}"
                Style="{StaticResource ButtonPrimary}" />
            <Button
                Width="100"
                Click="CancelButton_Click"
                Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Common_Cancel]}" />
        </StackPanel>
    </Grid>
</hc:Window>
