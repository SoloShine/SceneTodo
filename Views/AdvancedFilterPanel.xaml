<UserControl x:Class="SceneTodo.Views.AdvancedFilterPanel"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:hc="https://handyorg.github.io/handycontrol"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:services="clr-namespace:SceneTodo.Services"
               mc:Ignorable="d"
               d:DesignHeight="250" d:DesignWidth="700">
    <Border Background="{DynamicResource RegionBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Quick Filters Row -->
            <Border Grid.Row="0"
                    Background="{DynamicResource SecondaryRegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="0,0,0,12">
                <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Filter_QuickFilters]}"
                          FontSize="12"
                          FontWeight="SemiBold"
                          Foreground="{DynamicResource SecondaryTextBrush}"/>
            </Border>

            <!-- Two-Column Layout -->
            <Grid Grid.Row="1" Margin="0,12,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column: Priority & Completion -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <!-- Priority -->
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Filter_Priority]}"
                              FontSize="11"
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource SecondaryTextBrush}"
                              Margin="0,0,0,6"/>
                    <WrapPanel Margin="0,0,0,12">
                        <CheckBox Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Filter_Priority_VeryHigh]}"
                                 Tag="VeryHigh"
                                 Checked="PriorityCheckBox_Changed"
                                 Unchecked="PriorityCheckBox_Changed"
                                 Margin="0,0,12,4"
                                 Style="{StaticResource CheckBoxBaseStyle}"/>
                        <CheckBox Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Priority_High]}"
                                 Tag="High"
                                 Checked="PriorityCheckBox_Changed"
                                 Unchecked="PriorityCheckBox_Changed"
                                 Margin="0,0,12,4"
                                 Style="{StaticResource CheckBoxBaseStyle}"/>
                        <CheckBox Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Priority_Medium]}"
                                 Tag="Medium"
                                 Checked="PriorityCheckBox_Changed"
                                 Unchecked="PriorityCheckBox_Changed"
                                 Margin="0,0,12,4"
                                 Style="{StaticResource CheckBoxBaseStyle}"/>
                        <CheckBox Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Priority_Low]}"
                                 Tag="Low"
                                 Checked="PriorityCheckBox_Changed"
                                 Unchecked="PriorityCheckBox_Changed"
                                 Margin="0,0,12,4"
                                 Style="{StaticResource CheckBoxBaseStyle}"/>
                        <CheckBox Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Filter_Priority_VeryLow]}"
                                 Tag="VeryLow"
                                 Checked="PriorityCheckBox_Changed"
                                 Unchecked="PriorityCheckBox_Changed"
                                 Margin="0,0,0,4"
                                 Style="{StaticResource CheckBoxBaseStyle}"/>
                    </WrapPanel>

                    <!-- Completion Status -->
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Filter_CompletionStatus]}"
                              FontSize="11"
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource SecondaryTextBrush}"
                              Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[CompletionStatus_All]}"
                               Tag="All"
                               Click="CompletionStatusButton_Click"
                               Style="{StaticResource ButtonDefault}"
                               Padding="12,4"
                               Height="28"
                               Margin="0,0,4,0"/>
                        <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[CompletionStatus_Completed]}"
                               Tag="Completed"
                               Click="CompletionStatusButton_Click"
                               Style="{StaticResource ButtonDefault}"
                               Padding="12,4"
                               Height="28"
                               Margin="0,0,4,0"/>
                        <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[CompletionStatus_Incomplete]}"
                               Tag="Incomplete"
                               Click="CompletionStatusButton_Click"
                               Style="{StaticResource ButtonDefault}"
                               Padding="12,4"
                               Height="28"/>
                    </StackPanel>

                    <!-- Quick Action Buttons -->
                    <WrapPanel>
                        <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[QuickFilter_TodayDue]}"
                               Click="QuickFilterTodayDue_Click"
                               Style="{StaticResource ButtonPrimary}"
                               Height="28"
                               Padding="12,4"
                               Margin="0,0,4,4"/>
                        <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[QuickFilter_Overdue]}"
                               Click="QuickFilterOverdue_Click"
                               Style="{StaticResource ButtonDanger}"
                               Height="28"
                               Padding="12,4"
                               Margin="0,0,4,4"/>
                    </WrapPanel>
                </StackPanel>

                <!-- Right Column: Tags & Date -->
                <StackPanel Grid.Column="1">
                    <!-- Date Filters -->
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Filter_DueDate]}"
                              FontSize="11"
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource SecondaryTextBrush}"
                              Margin="0,0,0,6"/>
                    <ComboBox x:Name="DueDateFilterComboBox"
                             SelectionChanged="DueDateFilterComboBox_SelectionChanged"
                             Margin="0,0,0,12"
                             SelectedIndex="0"
                             Height="28"
                             Style="{StaticResource ComboBoxBaseStyle}">
                        <ComboBoxItem Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[FilterDate_All]}" Tag="All"/>
                        <ComboBoxItem Content="Today" Tag="Today"/>
                        <ComboBoxItem Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[FilterDate_ThisWeek]}" Tag="ThisWeek"/>
                        <ComboBoxItem Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[FilterDate_ThisMonth]}" Tag="ThisMonth"/>
                        <ComboBoxItem Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[QuickFilter_Overdue]}" Tag="Overdue"/>
                        <ComboBoxItem Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[FilterDate_CustomRange]}" Tag="Custom"/>
                    </ComboBox>

                    <StackPanel x:Name="CustomDateRangePanel" Visibility="Collapsed" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <hc:DatePicker Grid.Column="0" x:Name="StartDatePicker"
                                          Height="28"/>
                            <TextBlock Grid.Column="1" Text="-" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <hc:DatePicker Grid.Column="2" x:Name="EndDatePicker"
                                          Height="28"/>
                        </Grid>
                    </StackPanel>

                    <!-- Tags -->
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Filter_Tags]}"
                              FontSize="11"
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource SecondaryTextBrush}"
                              Margin="0,0,0,6"/>
                    <ListBox x:Name="TagsListBox"
                            SelectionMode="Multiple"
                            SelectionChanged="TagsListBox_SelectionChanged"
                            MaxHeight="80"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource BorderBrush}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8"
                                            Fill="{Binding ColorBrush}"
                                            Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding Name}" FontSize="12"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Grid>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Common_Reset]}"
                       Click="ResetFilter_Click"
                       Style="{StaticResource ButtonDefault}"
                       Height="28"
                       Padding="12,4"/>
                <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Common_Apply]}"
                       Click="ApplyFilter_Click"
                       Style="{StaticResource ButtonPrimary}"
                       Height="28"
                       Padding="16,4"
                       Margin="8,0,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
