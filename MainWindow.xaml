<hc:Window
x:Class="SceneTodo.MainWindow"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:hc="https://handyorg.github.io/handycontrol"
xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
xmlns:views="clr-namespace:SceneTodo.Views"
xmlns:vm="clr-namespace:SceneTodo.ViewModels"
xmlns:services="clr-namespace:SceneTodo.Services"
Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[App_Title]}"
Width="800"
Height="450"
Background="{DynamicResource RegionBrush}"
WindowStartupLocation="CenterScreen">
    <hc:Window.InputBindings>
        <KeyBinding Key="F" Modifiers="Control" Command="{Binding ToggleFilterPanelCommand}"/>
    </hc:Window.InputBindings>
    <hc:Window.Resources>
        <Style
            x:Key="menuButton"
            BasedOn="{StaticResource ButtonBaseStyle}"
            TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </hc:Window.Resources>
    <!--  主内容区域  -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="150" />
        </Grid.ColumnDefinitions>
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <!--  菜单  -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <hc:SideMenu>
                        <hc:SideMenuItem Command="{Binding ShowTodoListPageCommand}" ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Menu_TodoListView]}">
                            <hc:SideMenuItem.Icon>
                                <iconPacks:PackIconFontAwesome Kind="FaceSmileRegular" />
                            </hc:SideMenuItem.Icon>
                        </hc:SideMenuItem>
                        <hc:SideMenuItem Command="{Binding ShowCalendarViewCommand}" ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Menu_CalendarView]}">
                            <hc:SideMenuItem.Icon>
                                <iconPacks:PackIconCircumIcons Kind="Calendar" />
                            </hc:SideMenuItem.Icon>
                        </hc:SideMenuItem>
                        <hc:SideMenuItem Command="{Binding ShowScheduledTasksCommand}" ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Menu_ScheduledTasks]}">
                            <hc:SideMenuItem.Icon>
                                <iconPacks:PackIconFontAwesome Kind="ClockRegular" />
                            </hc:SideMenuItem.Icon>
                        </hc:SideMenuItem>
                        <hc:SideMenuItem Command="{Binding ShowHistoryPageCommand}" ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Menu_History]}">
                            <hc:SideMenuItem.Icon>
                                <iconPacks:PackIconMaterialDesign Kind="History" />
                            </hc:SideMenuItem.Icon>
                        </hc:SideMenuItem>
                    </hc:SideMenu>
                </StackPanel>
                <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
                    <hc:ContextMenuButton Style="{StaticResource menuButton}" ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Menu_Settings]}">
                        <hc:ContextMenuButton.Content>
                            <iconPacks:PackIconVaadinIcons Kind="Cog" />
                        </hc:ContextMenuButton.Content>
                        <hc:ContextMenuButton.Menu>
                            <ContextMenu>
                                <MenuItem Command="{Binding OpenAppearanceSettingsCommand}" Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_Appearance]}">
                                    <MenuItem.Icon>
                                        <iconPacks:PackIconMaterialDesign Kind="Palette" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Command="{Binding OpenLanguageSettingsCommand}" Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_Language]}">
                                    <MenuItem.Icon>
                                        <iconPacks:PackIconMaterialDesign Kind="Translate" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Command="{Binding ThemeSettingsCommand}" Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_Theme_Old]}">
                                    <MenuItem.Icon>
                                        <iconPacks:PackIconLucide Kind="Palette" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Command="{Binding BackupManagementCommand}" Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_Backup]}">
                                    <MenuItem.Icon>
                                        <iconPacks:PackIconBootstrapIcons Kind="Database" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Command="{Binding ResetAppConfigCommand}" Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_ResetConfig]}">
                                    <MenuItem.Icon>
                                        <iconPacks:PackIconIonicons Kind="RefreshMD" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Command="{Binding ResetTodoCommand}" Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_ResetData]}">
                                    <MenuItem.Icon>
                                        <iconPacks:PackIconBoxIcons Kind="RegularReset" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </hc:ContextMenuButton.Menu>
                    </hc:ContextMenuButton>
                    <Button
                        Command="{Binding AboutCommand}"
                        Style="{StaticResource menuButton}"
                        ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Menu_Help]}">
                        <Button.Content>
                            <iconPacks:PackIconLucide Kind="CircleHelp" />
                        </Button.Content>
                    </Button>
                </StackPanel>

            </Grid>


        </Border>
        <!-- 主内容区 - 使用 ContentControl 实现页面切换 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <!-- 搜索栏 -->
                <RowDefinition Height="Auto"/>
                <!-- 内容区域 -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 搜索栏 -->
            <Border Grid.Row="0"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,8"
                    Visibility="{Binding IsSearchVisible, Converter={StaticResource Boolean2VisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 搜索框 -->
                    <hc:SearchBar Grid.Column="0"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 hc:InfoElement.Placeholder="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Search_Placeholder]}"
                                 IsEnabled="{Binding IsSearching, Converter={StaticResource Boolean2BooleanReConverter}}"
                                 Margin="0,0,8,0"/>

                    <!-- 筛选切换按钮 -->
                    <Button x:Name="FilterButton"
                           Grid.Column="1"
                           Command="{Binding ToggleFilterPanelCommand}"
                           Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Filter_Button]}"
                           Style="{StaticResource ButtonDefault}"
                           Margin="0,0,8,0">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterialDesign Kind="Filter" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Filter_Button]}"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>

                    <!-- 清除搜索按钮 -->
                    <Button Grid.Column="2"
                           Command="{Binding ClearSearchCommand}"
                           Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Common_Clear]}"
                           Style="{StaticResource ButtonDefault}"/>
                </Grid>
            </Border>

            <!-- 内容 -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentContent}" />

            <!-- 筛选面板 Popup -->
            <Popup IsOpen="{Binding IsFilterPanelVisible}"
                   Placement="Bottom"
                   PlacementTarget="{Binding ElementName=FilterButton}"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade"
                   HorizontalOffset="-10"
                   VerticalOffset="10">
                <Border Background="{DynamicResource RegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="0"
                        Width="400"
                        MaxHeight="600">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 标题栏 -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource SecondaryRegionBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                          Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AdvancedFilter_Title]}"
                                          FontSize="14"
                                          FontWeight="SemiBold"
                                          VerticalAlignment="Center"/>

                                <Button Grid.Column="1"
                                       Command="{Binding ToggleFilterPanelCommand}"
                                       Width="24"
                                       Height="24"
                                       Padding="0"
                                       Style="{StaticResource ButtonIcon}"
                                       ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Common_Close]}">
                                    <iconPacks:PackIconMaterialDesign Kind="Close" Width="14" Height="14"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- 筛选面板内容 -->
                        <ScrollViewer Grid.Row="1"
                                    VerticalScrollBarVisibility="Auto">
                            <views:AdvancedFilterPanel DataContext="{Binding}"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Popup>
        </Grid>
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <!--  标签管理面板  -->
                <RowDefinition Height="*"/>
                <!--  时钟小组件  -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标签管理面板 -->
            <views:TagsPanelControl Grid.Row="0" 
                                   x:Name="TagsPanel"
                                   TagFilterRequested="TagsPanel_TagFilterRequested"/>

            <!-- 时钟小组件 -->
            <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
                <Viewbox MaxWidth="200">
                    <hc:FlipClock Margin="32" />
                </Viewbox>
            </StackPanel>
        </Grid>

    </Grid>
</hc:Window>
